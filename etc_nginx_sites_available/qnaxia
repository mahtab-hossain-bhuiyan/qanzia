server {
    listen 443 ssl;
    server_name qnaxia.com;

    ssl_certificate /etc/letsencrypt/live/qnaxia.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/qnaxia.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    gzip on;
    gzip_types text/plain text/css application/javascript application/json;
    gzip_min_length 1000;

    root /var/www/qanzia/public;

    # Serve index.html for root
    location = / {
        try_files /index.html =404;
    }

    # Serve about.html for /about
    location = /about {
        try_files /about.html =404;
    }

    # Serve contact.html for /contact
    location = /contact {
        try_files /contact.html =404;
    }

    # Serve privacy.html for /privacy
    location = /privacy {
        try_files /privacy.html =404;
    }

    # Serve robots.txt
    location = /robots.txt {
        try_files /robots.txt =404;
    }

    # Serve static files
    location ~* \.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$ {
        try_files $uri =404;
    }

    # API -> Node
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
    }

    # Sitemap -> Node
    location = /sitemap.xml {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
    }

    # Everything else (SPA) - fallback to index.html
    location / {
        try_files $uri $uri/ /index.html =404;
    }
}